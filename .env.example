# =======================================
# LLM API Configuration
# =======================================

# URL of the LLM endpoint used to generate movie search plans
LLM_API_URL=https://whgjf3nuoysl5swwb6vcnhew.agents.do-ai.run/api/v1/chat/completions

# API token for authenticating with the LLM provider
LLM_API_TOKEN=your_llm_api_token_here

# Model name used by the LLM
LLM_MODEL=openai/gpt-oss-120b


# =======================================
# TMDB API Configuration
# =======================================

# Your TMDB API key for movie search and metadata
TMDB_API_KEY=your_tmdb_api_key_here


# =======================================
# Server Configuration
# =======================================

# Port for the Express server
PORT=3000


# =======================================
# Database Configuration
# =======================================

# Path to your SQLite database file
DB_FILE=src/backend/database/movies_recommendation.db
